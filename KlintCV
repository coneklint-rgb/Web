        </div>
    </footer>

    <!-- AI Response Modal -->
    <div id="ai-modal" class="modal fixed inset-0 bg-gray-900 bg-opacity-75 flex items-center justify-center p-4 z-50 opacity-0 pointer-events-none">
        <div class="modal-content bg-white rounded-lg shadow-xl w-full max-w-2xl transform -translate-y-10">
            <div class="p-6">
                <div class="flex justify-between items-center border-b pb-3 mb-4">
                    <h3 class="text-2xl font-bold text-slate-800">✨ AI-Generated Response</h3>
                    <button id="close-modal-btn" class="text-slate-500 hover:text-slate-800 text-3xl leading-none">&times;</button>
                </div>
                <div id="modal-body" class="text-slate-600 leading-relaxed max-h-[60vh] overflow-y-auto pr-2"></div>
            </div>
        </div>
    </div>

    <script>
        // --- DOM Elements ---
        const menuBtn = document.getElementById('menu-btn');
        const getStrategyBtn = document.getElementById('get-strategy-btn');
        const getAiAnswerBtn = document.getElementById('get-ai-answer-btn');
        const sendMessageBtn = document.getElementById('send-message-btn');
        const strategyPromptEl = document.getElementById('strategy-prompt');
        const questionEl = document.getElementById('question');
        const formFeedback = document.getElementById('form-feedback');
        const aiModal = document.getElementById('ai-modal');
        const modalBody = document.getElementById('modal-body');
        const closeModalBtn = document.getElementById('close-modal-btn');
        const tabBtns = document.querySelectorAll('.tab-btn');
        const tabContents = document.querySelectorAll('.tab-content');

        // --- Mobile Menu (Not used in this layout, but kept for smaller screens if needed) ---
        // menuBtn.addEventListener('click', () => { /* ... */ });

        // --- Tab Controls ---
        tabBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                tabBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                
                const tabId = btn.dataset.tab;
                tabContents.forEach(content => {
                    if (content.id === `${tabId}-content`) {
                        content.classList.remove('hidden');
                    } else {
                        content.classList.add('hidden');
                    }
                });
            });
        });

        // --- Modal Controls ---
        function openModal() {
            aiModal.classList.remove('opacity-0', 'pointer-events-none');
            aiModal.classList.add('modal-active');
            aiModal.querySelector('.modal-content').classList.remove('-translate-y-10');
        }
        function closeModal() {
            aiModal.classList.add('opacity-0');
            aiModal.querySelector('.modal-content').classList.add('-translate-y-10');
            setTimeout(() => {
                aiModal.classList.add('pointer-events-none');
                aiModal.classList.remove('modal-active');
            }, 250);
        }
        closeModalBtn.addEventListener('click', closeModal);
        aiModal.addEventListener('click', (e) => e.target === aiModal && closeModal());

        // --- Gemini API Call Function ---
        async function callGeminiAPI(prompt) {
            const apiKey = ""; // Placeholder
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-05-20:generateContent?key=${apiKey}`;
            const payload = { contents: [{ parts: [{ text: prompt }] }] };

            try {
                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!response.ok) throw new Error(`API error: ${response.status}`);
                const result = await response.json();
                const text = result.candidates?.[0]?.content?.parts?.[0]?.text;
                return text || "Could not generate a response.";
            } catch (error) {
                console.error("Gemini API Error:", error);
                return `An error occurred: ${error.message}.`;
            }
        }

        // --- Feature Logic ---
        function showLoading() {
            modalBody.innerHTML = '<div class="flex justify-center items-center py-10"><div class="spinner"></div></div>';
            openModal();
        }
        function sanitizeHTML(str) {
            const temp = document.createElement('div');
            temp.textContent = str;
            return temp.innerHTML;
        }
        function displayResponse(text) {
            let html = sanitizeHTML(text)
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\n\s*-\s/g, '<br>• ')
                .replace(/\n/g, '<br>');
            modalBody.innerHTML = `<p>${html}</p>`;
        }
        
        // --- Event Listeners ---
        getStrategyBtn.addEventListener('click', async () => {
            const userInput = strategyPromptEl.value;
            if (!userInput.trim()) return alert('Please describe a supply chain challenge.');
            showLoading();
            const systemPrompt = `You are a world-class supply chain technology consultant with the expertise of Klint Cone (Nike, Walmart, Caterpillar). You specialize in TMS, global freight optimization, and cost reduction. Given the problem, provide a high-level, strategic, and actionable response. Problem: "${userInput}"`;
            const response = await callGeminiAPI(systemPrompt);
            displayResponse(response);
        });

        getAiAnswerBtn.addEventListener('click', async () => {
            const userInput = questionEl.value;
            if (!userInput.trim()) return alert('Please ask a question.');
            showLoading();
            const pageContent = document.body.innerText;
            const systemPrompt = `You are an AI assistant for Klint Cone's portfolio. Answer questions based *only* on the provided website content. Be concise. If the answer isn't in the text, say so. --- CONTENT --- ${pageContent} --- QUESTION --- "${userInput}"`;
            const response = await callGeminiAPI(systemPrompt);
            displayResponse(response);
        });

        sendMessageBtn.addEventListener('click', () => {
            const question = questionEl.value;
            if (!question.trim()) {
                formFeedback.textContent = 'Please enter a message.';
                formFeedback.className = 'mt-4 text-sm text-center text-red-600';
            } else {
                formFeedback.textContent = 'Thank you! Your message has been sent.';
                formFeedback.className = 'mt-4 text-sm text-center text-green-700';
                questionEl.value = '';
            }
            setTimeout(() => { formFeedback.textContent = ''; }, 4000);
        });
    </script>
</body>
