                            <div class="flex flex-wrap gap-2">
                                <span class="bg-purple-100 text-purple-800 text-sm font-medium px-3 py-1 rounded-full">DMAIC Six Sigma Black Belt</span>
                                <span class="bg-purple-100 text-purple-800 text-sm font-medium px-3 py-1 rounded-full">NASBITE CGBP</span>
